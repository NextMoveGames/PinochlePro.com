---
import BaseLayout from '../layouts/BaseLayout.astro';

// TODO: Replace with real RevenueCat Web Purchase Links once RC Web Billing is configured (#120)
const WEB_PURCHASE_LINKS = {
  monthly: '#subscribe-monthly',
  annual: '#subscribe-annual',
};
---
<BaseLayout
  title="Pricing — Pinochle Pro"
  description="Free to play with all rules. Subscribe for ad-free play, AI personalities, card themes, and more. One subscription covers both 4-hand and 3-hand."
  canonical="/pricing"
>
  <h1 class="title">Try Free for 14 Days</h1>
  <p style="text-align:center; color:#555; margin-bottom: 8px;">
    Subscriber features are designed to help you <strong>improve faster</strong> — hints during play, post-hand analysis, and more. No charge until your trial ends.<br />
    <strong>One subscription covers both 4-hand and 3-hand Pinochle Pro.</strong>
  </p>

  <div class="pricing-grid">

    <!-- Free -->
    <div class="pricing-card">
      <h3>Free</h3>
      <div class="pricing-price">$0</div>
      <div class="pricing-period">forever</div>
      <ul class="pricing-features">
        <li>Full game — 4-hand &amp; 3-hand</li>
        <li>All rule options</li>
        <li>Advanced AI opponents</li>
        <li>Classic Bob, Shirley, &amp; Jed Characters</li>
        <li>Game statistics</li>
        <li class="excluded">Ads shown</li>
        <li class="excluded">Card themes &amp; backs</li>
        <li class="excluded">AI personalities</li>
        <li class="excluded">Hints system</li>
        <li class="excluded">Post-hand analysis</li>
      </ul>
      <a href="https://apps.apple.com/us/app/pinochle-pro/id567644839" target="_blank" rel="noopener" class="pricing-cta secondary">Download Free →</a>
    </div>

    <!-- Annual — featured -->
    <div class="pricing-card featured">
      <h3>Annual</h3>
      <div class="pricing-price">$49.99</div>
      <div class="pricing-period">per year · ~$4.17/month</div>
      <ul class="pricing-features">
        <li>Everything in Free</li>
        <li>Hints — learn as you play</li>
        <li>Post-hand analysis & replay</li>
        <li>Statistics dashboard</li>
        <li>Ad-free play</li>
        <li>AI personalities</li>
        <li>Card themes &amp; backs</li>
        <li>Both app variants covered</li>
      </ul>
      <a href={WEB_PURCHASE_LINKS.annual} class="pricing-cta" onclick="gtag && gtag('event', 'subscribe_cta_click', {plan: 'annual'})">Try Free for 14 Days →</a>
      <p class="comparison-note">Then $49.99/yr · Save ~17% vs monthly</p>
    </div>

    <!-- Monthly -->
    <div class="pricing-card">
      <h3>Monthly</h3>
      <div class="pricing-price">$4.99</div>
      <div class="pricing-period">per month</div>
      <ul class="pricing-features">
        <li>Everything in Free</li>
        <li>Hints — learn as you play</li>
        <li>Post-hand analysis & replay</li>
        <li>Statistics dashboard</li>
        <li>Ad-free play</li>
        <li>AI personalities</li>
        <li>Card themes &amp; backs</li>
        <li>Both app variants covered</li>
      </ul>
      <a href={WEB_PURCHASE_LINKS.monthly} class="pricing-cta secondary" onclick="gtag && gtag('event', 'subscribe_cta_click', {plan: 'monthly'})">Try Free for 14 Days →</a>
    </div>

  </div>

  <div class="feature-case">
    <div class="feature-case-label">Subscriber Feature</div>
    <h2>See exactly where you left points on the table.</h2>
    <p>After every hand, Post-Hand Analysis replays every trick and shows you the decisions that cost you — or won it. Your partner bid 28, you made 31, but left 6 points on the table in tricks 4 and 7. Now you know why, and you won't make the same mistake twice.</p>
    <p class="feature-case-sub">Hints work the same way — real-time guidance during play so you're learning from the AI, not just losing to it.</p>
  </div>

  <div class="section">
    <h2>Frequently Asked Questions</h2>

    <details style="margin-bottom:16px;">
      <summary style="cursor:pointer; font-weight:bold;">What happens after the 14-day free trial?</summary>
      <p style="padding: 12px 0 0;">After your trial ends, you'll be charged for the plan you selected — annual ($49.99/yr) or monthly ($4.99/mo). You can cancel anytime before the trial ends and you won't be charged.</p>
    </details>

    <details style="margin-bottom:16px;">
      <summary style="cursor:pointer; font-weight:bold;">Does one subscription cover both 4-hand and 3-hand?</summary>
      <p style="padding: 12px 0 0;">Yes. One Pinochle Pro subscription covers both PinochlePro (4-hand) and PinochlePro 3-Hand. You'll never need to pay twice for the same game.</p>
    </details>

    <details style="margin-bottom:16px;">
      <summary style="cursor:pointer; font-weight:bold;">I already bought the ad-free version. What happens to me?</summary>
      <p style="padding: 12px 0 0;">You keep your ad-free access permanently — that purchase is honored forever. New subscriber features (card themes, AI personalities, hints, etc.) require a subscription, but you'll never lose what you already paid for.</p>
    </details>

    <details style="margin-bottom:16px;">
      <summary style="cursor:pointer; font-weight:bold;">Can I subscribe on the website and use it on my iPhone?</summary>
      <p style="padding: 12px 0 0;">Yes. After subscribing on the web, you'll receive a Redemption Link — just tap it on your iPhone to activate your subscription in the app.</p>
    </details>

    <details>
      <summary style="cursor:pointer; font-weight:bold;">How do I manage or cancel my subscription?</summary>
      <p style="padding: 12px 0 0;">Web subscribers can manage through the <a href="https://billing.revenuecat.com/portal" target="_blank" rel="noopener">subscription portal</a>. iOS subscribers can manage through <strong>Settings → Apple ID → Subscriptions</strong>.</p>
    </details>
  </div>

  <p style="text-align:center; margin-top:32px; color:#888; font-size:0.9rem;">
    Questions? <a href="/support">Contact support</a> or <a href="/faq">see the full FAQ</a>.
  </p>
</BaseLayout>

<style>
  .feature-case {
    background: #f0f5ff;
    border-left: 4px solid #2a6db5;
    border-radius: 8px;
    padding: 24px 28px;
    margin: 40px 0;
  }

  .feature-case h2 {
    margin: 8px 0 12px;
    font-size: 1.3rem;
  }

  .feature-case p {
    color: #444;
    line-height: 1.6;
    margin: 0 0 10px;
  }

  .feature-case-label {
    font-size: 0.75rem;
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #2a6db5;
  }

  .feature-case-sub {
    color: #666 !important;
    font-size: 0.95rem;
  }

  details {
    padding: 8px 12px;
    background: #f9f9f9;
    border-radius: 6px;
    border: 1px solid #eee;
  }
  details summary {
    list-style: none;
  }
  details summary::-webkit-details-marker { display: none; }
</style>
